# Application
APP_SECRET_KEY=change-me-to-a-random-32-byte-key
# Optional: leave APP_SECRET_KEY at the default above and use Admin → Generate secret key,
# or let the app auto-generate on first startup (stored in APP_SECRET_KEY_FILE).
APP_SECRET_KEY_FILE=/data/secrets/app_secret_key
CREDENTIAL_ENCRYPTION_KEY=change-me-use-fernet-key
CREDENTIAL_ENCRYPTION_KEY_FILE=/data/secrets/credential_encryption_key

# Web UI host port (container always listens on 8080 internally)
WEB_HOST_PORT=8081

# Database
POSTGRES_USER=stig
POSTGRES_PASSWORD=stig
POSTGRES_DB=stigtool
DATABASE_URL=postgresql://stig:stig@postgres:5432/stigtool

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Paths (inside containers)
STIG_PROFILES_PATH=/usr/share/stigs
REPORTS_PATH=/data/reports
CKL_EXPORT_ALLOWED_ROOTS=/data/reports,/data/ckl-exports
# For a Windows SMB share mounted at /mnt/stig-ckl-export on the host, add:
# CKL_EXPORT_ALLOWED_ROOTS=/data/reports,/data/ckl-exports,/mnt/stig-ckl-export

# VCF 9.x profile paths (relative to STIG_PROFILES_PATH)
VCF_PROFILE_BASE=vcf/9.x/Y25M06-srg
VCF_BASELINE_PROFILE=inspec/vmware-cloud-foundation-stig-baseline/vsphere
VCF_VCSA_PROFILE=inspec/vmware-cloud-foundation-vcsa-stig-baseline
VCF_METADATA=inspec/vmware-cloud-foundation-stig-baseline/saf_cli_hdf2ckl_metadata.json

# Scan behavior
DRY_RUN=false
SCAN_TIMEOUT_SECONDS=7200

# Reverse proxy / subpath (match nginx location and Keycloak redirect URIs)
APP_ROOT_PATH=/vmstigtool
APP_PUBLIC_URL=https://stigman.tad.ds.usace.army.mil/vmstigtool

# OIDC / Keycloak (set OIDC_ENABLED=true in production)
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://keycloak.example.mil/realms/vmstig
OIDC_METADATA_URL=
# If the web container cannot reach the public Keycloak URL, use internal discovery:
# OIDC_METADATA_URL=http://keycloak:8080/realms/VMSTIGTool/.well-known/openid-configuration
# OIDC_TOKEN_URL=http://keycloak:8080/realms/VMSTIGTool/protocol/openid-connect/token
# OIDC_USERINFO_URL=http://keycloak:8080/realms/VMSTIGTool/protocol/openid-connect/userinfo
# OIDC_SSL_VERIFY=false only if you cannot mount a DoD CA bundle (not recommended)
# OIDC_CA_BUNDLE=/etc/ssl/certs/dod-trust.pem
OIDC_CLIENT_ID=vmstig-tool
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
